# DentalSync 백엔드 환경변수 — pydantic-settings 가 backend/.env 에서 로드
# (app/core/config.py 의 Settings 와 항상 동기화 유지)

# --- 일반 ---
ENVIRONMENT=local

# --- 인증 (Phase 1: 단일 베어러 토큰. 빈 값이면 인증 비활성 = 로컬 개발) ---
API_AUTH_TOKEN=

# --- CORS (프론트 origin, 콤마 구분) ---
CORS_ORIGINS=http://localhost:3000

# --- 데이터 스토어 ---
# 운영: NEON Postgres / 로컬 개발: sqlite 사용 가능 (scripts/dev_bootstrap.py 로 테이블 생성)
DATABASE_URL=postgresql+psycopg://dentalsync:dentalsync@localhost:5432/dentalsync
# DATABASE_URL=sqlite+pysqlite:///./data/dev.db
REDIS_URL=redis://localhost:6379
IMAGE_CACHE_TTL_SECONDS=604800

# --- 백엔드 구현 선택 (로컬 개발: mock/local/memory 로 외부 의존 없이 실행) ---
OCR_PROVIDER=clova            # clova | mock
STORAGE_BACKEND=r2            # r2 | local
CACHE_BACKEND=redis           # redis | memory
PUBLIC_BASE_URL=http://localhost:8000

# --- Naver CLOVA OCR (Template Basic) ---
CLOVA_API_KEY=
CLOVA_TEMPLATE_ID=
CLOVA_OCR_INVOKE_URL=
CLOVA_OCR_SECRET=

# --- OpenAI — Type C 텍스트 구조화 전용 (모델명 하드코딩 금지, ADR-0001) ---
OPENAI_API_KEY=
LLM_MODEL_PRIMARY=gpt-5-mini
LLM_MODEL_ESCALATION=gpt-5

# --- Cloudflare R2 (S3 호환) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
