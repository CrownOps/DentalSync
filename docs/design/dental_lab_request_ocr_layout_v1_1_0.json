  "validation_rules": [
    {
      "rule_key": "required_patient_name",
      "description": "환자명이 없으면 케이스 식별 불가",
      "condition": "case_basic.patient_name.value == null",
      "severity": "error",
      "sets_flag": "missing_required_fields",
      "message": "환자명이 누락되었습니다."
    },
    {
      "rule_key": "required_tooth_numbers",
      "description": "치식이 없으면 보철 제작 대상 확인 불가",
      "condition": "tooth.tooth_numbers.value.length == 0",
      "severity": "error",
      "sets_flag": "missing_required_fields",
      "message": "치식 정보가 누락되었습니다."
    },
    {
      "rule_key": "required_clinic_identity",
      "description": "치과명과 빨간펜 치과 앞글자가 모두 없으면 거래처 식별 불가",
      "condition": "case_basic.clinic_name.value == null AND internal_routing.clinic_initial.value == null",
      "severity": "warning",
      "sets_flag": "missing_required_fields",
      "message": "치과 식별 정보(치과명/내부 표기)가 누락되었습니다."
    },
    {
      "rule_key": "required_due_date",
      "description": "본문 납기와 내부 납품 요구일이 모두 없으면 작업 우선순위 설정 불가",
      "condition": "case_basic.due_date.value == null AND internal_routing.internal_due_date.value == null",
      "severity": "warning",
      "sets_flag": "due_date_ambiguous",
      "message": "납품 요구일이 누락되었습니다."
    },
    {
      "rule_key": "internal_body_due_date_mismatch",
      "description": "빨간펜 납품일과 의뢰서 본문 납기일이 다르면 확인 필요",
      "condition": "case_basic.due_date.value != null AND internal_routing.internal_due_date.value != null AND date(case_basic.due_date.value) != date(internal_routing.internal_due_date.value)",
      "severity": "warning",
      "sets_flag": "internal_body_due_mismatch",
      "message": "내부 표시 납품일과 의뢰서 본문 납기가 일치하지 않습니다."
    },
    {
      "rule_key": "implant_case_requires_manufacturer",
      "description": "임플란트 케이스인데 제조사가 없으면 확인 필요",
      "condition": "(prosthesis.prosthesis_category.value == 'implant_prosthesis' OR implant.is_implant_case.value == true) AND implant.implant_manufacturer.value == null",
      "severity": "warning",
      "sets_flag": "implant_info_missing",
      "message": "임플란트 제조사 정보가 누락되었습니다."
    },
    {
      "rule_key": "custom_abutment_requires_scanbody",
      "description": "커스텀 어버트먼트 케이스는 스캔바디 정보 확인 필요",
      "condition": "implant.is_custom_abutment.value == true AND abutment_scanbody.scanbody_manufacturer.value == null AND abutment_scanbody.scanbody_size.value == null",
      "severity": "warning",
      "sets_flag": "scanbody_info_missing",
      "message": "커스텀 어버트먼트 케이스이나 스캔바디 정보가 불명확합니다."
    },
    {
      "rule_key": "crown_requires_shade",
      "description": "외형(심미면) 제작이 포함된 케이스에서 쉐이드 누락은 리메이크 직결 위험",
      "condition": "prosthesis.prosthesis_category.value IN ['crown', 'bridge', 'implant_prosthesis', 'inlay', 'onlay', 'denture'] AND ('full_crown' IN prosthesis.prosthesis_type.value OR prosthesis.prosthesis_type.value.length == 0) AND manufacturing_conditions.shade.value == null",
      "severity": "warning",
      "sets_flag": "shade_missing",
      "message": "쉐이드가 누락되었습니다. (coping/abutment 단독 작업은 제외)"
    },
    {
      "rule_key": "scan_file_tooth_match",
