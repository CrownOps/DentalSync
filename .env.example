# ============================================================================
# DentalSync 환경변수 예시 — 이 파일을 복사해 사용한다. (실제 키는 절대 커밋 금지)
#   backend:  cp .env.example backend/.env
#   frontend: NEXT_PUBLIC_* 값은 frontend/.env.local 에 두거나 셸 환경에 주입
# ============================================================================

# ---- Frontend ----
# 브라우저가 호출할 backend 베이스 URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ---- Backend: 일반 ----
ENVIRONMENT=local

# ---- Backend: 인증 (Phase 1 단일 베어러 토큰) ----
# 빈 값이면 인증 비활성(로컬 개발). 운영(Railway)에서는 반드시 설정.
API_AUTH_TOKEN=

# ---- Backend: CORS ----
# 콤마로 여러 origin 지정 가능 (예: http://localhost:3000,http://127.0.0.1:3000)
CORS_ORIGINS=http://localhost:3000

# ---- Backend: 구현 선택 (로컬 개발: mock/local/memory 로 외부 의존 없이 실행) ----
OCR_PROVIDER=clova            # clova | mock
OCR_MODE=template             # template(콘솔 등록 양식 전용) | general(자유양식 전체텍스트+LLM 구조화)
LLM_PROVIDER=openai           # openai | mock
STORAGE_BACKEND=r2            # r2 | local
CACHE_BACKEND=redis           # redis | memory
PUBLIC_BASE_URL=http://localhost:8000

# ---- Backend: 데이터 스토어 ----
# 운영: NEON Postgres / 로컬 개발: 아래 sqlite 주석 사용 가능 (scripts/dev_bootstrap.py 로 테이블 생성)
DATABASE_URL=postgresql+psycopg://dentalsync:dentalsync@localhost:5432/dentalsync
# DATABASE_URL=sqlite+pysqlite:///./data/dev.db
# 로컬: redis://localhost:6379  /  프로덕션(Upstash): rediss://default:<token>@<host>:<port>
REDIS_URL=redis://localhost:6379
IMAGE_CACHE_TTL_SECONDS=604800

# ---- 외부 API: Naver CLOVA OCR ----
CLOVA_API_KEY=
CLOVA_TEMPLATE_ID=
CLOVA_OCR_INVOKE_URL=         # Template OCR Invoke URL (OCR_MODE=template)
CLOVA_GENERAL_INVOKE_URL=     # General OCR Invoke URL (OCR_MODE=general, 양식 무관)
CLOVA_OCR_SECRET=             # X-OCR-SECRET (Template/General 공용)

# ---- 외부 API: OpenAI (Type C 자유텍스트 구조화 전용 — 이미지 입력 금지) ----
OPENAI_API_KEY=
# Type C 1차(경량) 모델. 기본값: gpt-5-mini
LLM_MODEL_PRIMARY=
# 검증 실패 시 승급 모델. 기본값: gpt-5
LLM_MODEL_ESCALATION=

# ---- 오브젝트 스토리지: Cloudflare R2 (S3 호환) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
